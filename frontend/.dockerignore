# ============================================================
# 前端 .dockerignore - 排除构建上下文无关文件
# ============================================================

# 依赖目录
node_modules
node_modules/

# 构建产物
dist
dist/
build
build/

# 开发与调试
.vscode
.idea
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 临时文件
.DS_Store
*.swp
*.swo
*~
*.tmp
*.temp

# 环境变量
.env
.env.local
.env.*.local

# 测试相关
coverage
.nyc_output
tests/
__tests__/
*.spec.js
*.test.js

# 文档
README.md
*.md
docs/

# 截图与图片
*.png
*.jpg
*.jpeg
*.gif
screenshots/

# Git
.git
.gitignore
